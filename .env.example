# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Host port exposed by docker-compose (defaults to 3001)
HOST_PORT=3001

# Path where the built React app lives inside the container
STATIC_DIR=/app/public

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong random secret, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d
