.env.local
.env.*.local
coverage/
.nyc_output/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
Thumbs.db

# Git
.git/
.gitignore

# Docker files (not needed in the image itself)
docker-compose*.yml
